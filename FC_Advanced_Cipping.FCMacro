import FreeCAD as App
import FreeCADGui as Gui
import Part
import math

try:
    from PySide6 import QtCore, QtWidgets
except ImportError:
    from PySide2 import QtCore, QtWidgets

class LiveSectionAnalyzer(QtWidgets.QDockWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Interactive Section Analysis")
        self.setAllowedAreas(QtCore.Qt.LeftDockWidgetArea | QtCore.Qt.RightDockWidgetArea)
        
        self.base_obj = self.get_selection()
        if not self.base_obj:
            return
            
        self.bbox = self.base_obj.Shape.BoundBox
        self.diag = self.bbox.DiagonalLength
        
        # Calculate bounding box dimensions
        self.x_len = self.bbox.XMax - self.bbox.XMin
        self.y_len = self.bbox.YMax - self.bbox.YMin
        self.z_len = self.bbox.ZMax - self.bbox.ZMin
        
        # Calculate tolerance based on object size
        self.tolerance = max(self.x_len, self.y_len, self.z_len) * 1e-5
        self.tolerance = max(self.tolerance, 0.01)
        
        # Create all features once (for performance)
        self.section_feat = None
        self.edge_feat = None
        self.hatch_feat = None
        self.bg_feat = None
        self.frozen_counter = 0
        self.init_done = False
        self._updating = False
        self._update_timer = None
        
        self.init_ui()
        self.create_features()
        self.update_section()
        self.init_done = True

    def get_selection(self):
        sel = Gui.Selection.getSelection()
        if not sel:
            QtWidgets.QMessageBox.warning(None, "Error", "Please select a part from the Tree View first!")
            return None
        return sel[0]

    def create_features(self):
        """Create all features once"""
        doc = App.ActiveDocument
        if not doc:
            return
            
        # Background object
        self.bg_feat = doc.addObject("Part::Feature", "Live_Section_Background")
        self.bg_feat.ViewObject.ShapeColor = self.base_obj.ViewObject.ShapeColor
        self.bg_feat.ViewObject.DisplayMode = "Shaded"
        self.bg_feat.ViewObject.Transparency = 70
        
        # Section fill (optional - default off)
        self.section_feat = doc.addObject("Part::Feature", "Live_Section_Fill")
        self.section_feat.ViewObject.ShapeColor = (0.75, 0.65, 0.68)
        self.section_feat.ViewObject.LineColor = (0.0, 0.0, 0.0)
        self.section_feat.ViewObject.LineWidth = 3.0
        self.section_feat.ViewObject.DisplayMode = "Shaded"
        self.section_feat.ViewObject.Transparency = 0
        self.section_feat.ViewObject.Visibility = False
        
        # Section edge lines
        self.edge_feat = doc.addObject("Part::Feature", "Live_Section_Edges")
        self.edge_feat.ViewObject.LineColor = (0.0, 0.0, 0.0)
        self.edge_feat.ViewObject.LineWidth = 2.0
        self.edge_feat.ViewObject.DisplayMode = "Flat Lines"
        self.edge_feat.ViewObject.DrawStyle = "Solid"
        self.edge_feat.ViewObject.Visibility = False
        self.edge_feat.ViewObject.PointSize = 1
        
        # Hatch lines - ANSI 31 standard (dark gray/black)
        self.hatch_feat = doc.addObject("Part::Feature", "Live_Hatch_Lines")
        self.hatch_feat.ViewObject.LineColor = (0.2, 0.2, 0.2)
        self.hatch_feat.ViewObject.LineWidth = 1.0
        self.hatch_feat.ViewObject.DisplayMode = "Flat Lines"
        self.hatch_feat.ViewObject.DrawStyle = "Solid"
        self.hatch_feat.ViewObject.Visibility = False
        self.hatch_feat.ViewObject.PointSize = 1
        
        doc.recompute()

